@{
    ViewData["Title"] = "Home";
}

<div class="container py-4 py-lg-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">
            <h1 class="h3 mb-2">Dashboard</h1>

            <div class="d-flex flex-wrap gap-2 mb-4">
                <a class="btn btn-primary" asp-controller="Book" asp-action="Index">Browse Books</a>
                <button type="button" class="btn btn-outline-primary" disabled>Categories</button>
                <button type="button" class="btn btn-outline-primary" disabled>Orders</button>
                <button type="button" class="btn btn-outline-secondary" disabled>Reports</button>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="fw-semibold">Books</div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a class="btn btn-sm btn-outline-primary w-100" asp-controller="Book" asp-action="Index">Browse</a>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="fw-semibold">Categories</div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <button type="button" class="btn btn-sm btn-outline-primary w-100" disabled>Open</button>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="fw-semibold">Orders</div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <button type="button" class="btn btn-sm btn-outline-primary w-100" disabled>Open</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
